    "jiti": "^2.6.1",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
