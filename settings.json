{
  "model": "claude-sonnet-4-6",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "MAX_THINKING_TOKENS": "10000"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/kruzy/.claude-config/scripts/session-start.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/kruzy/.claude-config/scripts/session-end.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/kruzy/.claude-config/scripts/pre-compact.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs'),path=require('path'),os=require('os');let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const cmd=j.tool_input&&j.tool_input.command||'';const blocked=['rm -rf /','format C:','DROP TABLE','dd if='];for(const b of blocked){if(cmd.includes(b)){process.stderr.write('BLOCKED: Dangerous command: '+cmd);process.exit(2);}}const logDir=path.join(os.homedir(),'.claude-config','logs');if(!fs.existsSync(logDir))fs.mkdirSync(logDir,{recursive:true});fs.appendFileSync(path.join(logDir,'bash-log.txt'),new Date().toISOString()+' '+cmd+'\\n');process.exit(0);}catch(e){process.exit(0);}})\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const cmd=j.tool_input&&j.tool_input.command||'';if(cmd.includes('git push')){process.stderr.write('REMINDER: About to push. Run /review first.');}process.exit(0);}catch(e){process.exit(0);}})\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const fp=j.tool_input&&j.tool_input.file_path||'';const allowed=['README.md','CLAUDE.md','CLAUDE.local.md','AGENTS.md','CONTRIBUTING.md','CHANGELOG.md','CODEMAP.md'];const ext=fp.split('.').pop().toLowerCase();if((ext==='md'||ext==='txt')&&!allowed.some(a=>fp.endsWith(a))&&!fp.includes('.claude')){process.stderr.write('BLOCKED: Creating docs outside allowed patterns.');process.exit(2);}process.exit(0);}catch(e){process.exit(0);}})\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs'),path=require('path'),os=require('os');const counterFile=path.join(os.homedir(),'.claude-config','logs','tool-count.txt');try{const logDir=path.dirname(counterFile);if(!fs.existsSync(logDir))fs.mkdirSync(logDir,{recursive:true});let count=0;try{count=parseInt(fs.readFileSync(counterFile,'utf8'),10)||0;}catch(e){}count++;fs.writeFileSync(counterFile,String(count));if(count%50===0&&count>0){process.stderr.write('INFO: '+count+' tool calls. Consider /compact between phases.');}process.exit(0);}catch(e){process.exit(0);}\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/kruzy/.claude-config/scripts/post-edit-format.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/kruzy/.claude-config/scripts/post-edit-typecheck.js",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const fp=j.tool_input&&j.tool_input.file_path||'';const ext=fp.split('.').pop().toLowerCase();if(['ts','tsx','js','jsx'].includes(ext)){const content=fs.readFileSync(fp,'utf8');const matches=content.match(/console\\.log\\s*\\(/g);if(matches){process.stderr.write('WARNING: console.log in '+fp);}}process.exit(0);}catch(e){process.exit(0);}})\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const out=j.tool_output&&j.tool_output.stdout||j.tool_output||'';const m=String(out).match(/github\\.com\\/[^\\/]+\\/[^\\/]+\\/pull\\/[0-9]+/g);if(m){process.stderr.write('PR created: https://'+m[0]+' - run /review to check');}process.exit(0);}catch(e){process.exit(0);}})\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/kruzy/.claude-config/scripts/check-console-log.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\peon.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\kruzy\\.claude\\hooks\\peon-ping\\scripts\\hook-handle-use.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "autoUpdatesChannel": "latest"
}
