# ConfigCat SDK key (get from https://app.configcat.com → SDK Key)
# If not set, feature flags fall back to config.ts values
VITE_CONFIGCAT_SDK_KEY=

# Local feature flag overrides (for development)
# Set to "true" or "false" to override ConfigCat/config.ts values
# VITE_FF_DECADES=true
# VITE_FF_INTERNATIONAL=true
